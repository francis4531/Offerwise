<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logging Out - OfferWise AI</title>
</head>
<body>
    <script>
        // Clear ALL localStorage when logging out
        console.log('Clearing localStorage on logout...');
        localStorage.clear();
        
        // Redirect to home
        window.location.href = '/';
    </script>
    <p>Logging out...</p>
</body>
</html>
