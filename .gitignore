# v5.89.57: trained model artifacts. Never commit binary models to git —
# they're bulky (~3.5MB per model), go stale immediately when the corpus
# changes, and as of v5.89.55 live on persistent disk (/var/data/models/)
# in production. The .gitkeep sentinel is kept so the directory exists
# in dev/test environments that fall back to <app_dir>/models/.
models/*.xgb
models/*.pkl
